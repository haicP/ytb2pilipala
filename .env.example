APP_ENV=development
DATABASE_URL=sqlite:///./data/app.db
API2KEY_BASE_URL=
LLM_API_KEY=
TTS_PROVIDER=mimo_v2_5_tts
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts-voiceclone
MIMO_TTS_VOICE=冰糖
MIMO_TTS_STYLE_PROMPT=请用自然、清晰、适合中文视频解说的语气朗读。
MIMO_TTS_TIMEOUT_SECONDS=600
MIMO_TTS_CONCURRENCY=10
TTS_CONCURRENCY=10
OPENAI_TTS_API_KEY=
OPENAI_API_KEY=
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
